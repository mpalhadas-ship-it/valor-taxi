{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "independencia.valor.taxi.br" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "jardimnorte.valor.taxi.br" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "rodoviaria.valor.taxi.br" }],
      "destination": "/$1"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "painel.valor.taxi.br" }],
      "destination": "/painel.html"
    }
  ]
}
